STT=your_deepgram_api_key
FLUENCY_API_URL=https://your-cloud-run-url.run.app
OLLAMA_URL=http://192.168.x.x:11434/api/chat
# pronunciation_engine runs locally on port 8001 by default.
# For physical Android devices, either set this to your LAN IP
# (http://192.168.x.x:8001) or run `adb reverse tcp:8001 tcp:8001`
# and keep it on 127.0.0.1.
PRONUNCIATION_API_URL=http://127.0.0.1:8001